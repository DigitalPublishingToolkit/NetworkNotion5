			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/normal" FontStyle="08 Regular" PointSize="9.5" Ligatures="false" StrokeWeight="0.06" Tracking="40" StrokeColor="Color/Black" AppliedLanguage="$ID/English: USA" EndJoin="RoundEndJoin">
