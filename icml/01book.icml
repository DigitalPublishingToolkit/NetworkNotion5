		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/$ID/[No paragraph style]" Hyphenation="false">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/normal">
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/Page &gt; Running Text%3aNotes%3aFootnote" Hyphenation="false">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/normal" PointSize="9.5">
				<Content>Stuart Russell, Daniel Dewey, and Max Tegmark. ‘Research priorities for robust and beneficial artificial intelligence’. </Content>
